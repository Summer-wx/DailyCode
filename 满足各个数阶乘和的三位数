#include <stdio.h>
#include <stdlib.h>

int f(int n){
  int i,sum=1;
  for(i=1;i<=n;i++){
    sum*=i;
  }
  return sum;
}

int main(int argc, char *argv[])
{
  // 请在此输入您的代码
  int i;
  for(i=100;i<1000;i++){
    int a,b,c;
    a=i%10;
    b=i/10%10;
    c=i/100; 
    if (f(a)+f(b)+f(c)==i) printf("%d",i);  
  }
  return 0;
}
